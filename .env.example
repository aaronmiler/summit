# Copy to .env for local development (`cp .env.example .env`).
# Defaults already match the shared local postgres:16 container, so .env is
# optional for DB connectivity — it exists mainly for the LLM credentials below.

# --- Database (shared local postgres:16 container) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# --- LLM routing via litellm (not wired up yet) ---
LITELLM_BASE_URL=
LITELLM_API_KEY=
