<!DOCTYPE html>
<!-- data-theme="auto" opts Summit into Cascadia's native dark mode: follows the
     OS. Change to "dark"/"light" to force one. color-scheme themes UA chrome
     (form controls, scrollbars) to match. -->
<html lang="en" data-theme="auto">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light dark">
    <meta name="theme-color" content="#1B2131">
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32">
    <link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/manifest.webmanifest">
    <title>Summit</title>
    <%= vite_client_tag %>
    <%= vite_react_refresh_tag %>
    <%= vite_typescript_tag "application.tsx" %>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
